---
import Default from '@astrojs/starlight/components/Head.astro';
import { Font } from 'astro:assets';
---

<Default><slot /></Default>
{/* Preload both fonts so they are ready before first paint. Combined with
    font-display: optional this prevents any visible font swap. The mono font
    is preloaded too because the hero terminal uses it above the fold. */}
<Font cssVariable="--font-geist" preload />
<Font cssVariable="--font-geist-mono" preload />
